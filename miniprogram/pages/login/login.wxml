<view class="container">
  <view class="page-hero">
    <view class="brand-mark">随</view>
    <view class="title">术后随访</view>
    <view class="subtitle">登录后查看随访任务、拔管提醒和检查结果。</view>
  </view>

  <view class="form-card">
    <view class="card-title">正式使用</view>
    <view class="segmented">
      <button class="segment-btn {{mode==='login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">账号登录</button>
      <button class="segment-btn {{mode==='register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode">注册账号</button>
    </view>

    <view class="field">
      <view class="field-label">手机号</view>
      <input class="form-input" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" />
    </view>
    <view class="field">
      <view class="field-label">密码</view>
      <input class="form-input" password value="{{password}}" bindinput="onPasswordInput" placeholder="请输入 6 到 32 位密码" />
    </view>

    <view wx:if="{{mode==='register'}}">
      <view class="field-label">注册身份</view>
      <radio-group class="role-grid" bindchange="onRoleChange">
        <label class="role-option"><radio value="patient" checked="{{role==='patient'}}" />患者</label>
        <label class="role-option"><radio value="doctor" checked="{{role==='doctor'}}" />医生</label>
        <label class="role-option"><radio value="nurse" checked="{{role==='nurse'}}" />护士</label>
        <label class="role-option"><radio value="admin" checked="{{role==='admin'}}" />管理员</label>
      </radio-group>
      <view wx:if="{{role!=='patient'}}" class="field">
        <view class="field-label">身份码</view>
        <input class="form-input" password value="{{identityCode}}" bindinput="onIdentityCodeInput" placeholder="请输入医院发放的身份码" />
      </view>
      <view class="notice-box">患者注册后自动匹配同手机号档案。医生、护士、管理员注册需要医院身份码。</view>
    </view>

    <checkbox-group class="agreement-row" bindchange="onAgreementChange">
      <label class="agreement-check">
        <checkbox value="agree" checked="{{agreedToTerms}}" />
        <text>我已阅读并同意</text>
      </label>
      <text class="agreement-link" bindtap="openUserAgreement">《用户服务协议》</text>
      <text>和</text>
      <text class="agreement-link" bindtap="openPrivacyPolicy">《隐私政策》</text>
    </checkbox-group>

    <button class="primary-btn" loading="{{loading}}" bindtap="submitAccount">
      {{mode==='register' ? '注册并进入' : '登录'}}
    </button>
  </view>
</view>
