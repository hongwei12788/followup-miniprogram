<view class="container">
  <view class="page-hero">
    <view class="eyebrow">个人中心</view>
    <view class="title">我的</view>
    <view class="subtitle">这里展示当前登录账号的基础信息。</view>
  </view>

  <view class="profile-card" wx:if="{{user}}">
    <view class="card-title">个人资料</view>
    <view class="profile-row">
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">头像</view>
      </button>
      <view class="profile-fields">
        <view class="field-label">昵称</view>
        <input class="form-input" type="nickname" value="{{nickName}}" bindinput="onNickNameInput" placeholder="请输入昵称" />
      </view>
    </view>
    <button class="primary-btn" bindtap="saveProfile">保存资料</button>
  </view>

  <view class="profile-card" wx:if="{{user}}">
    <view class="card-title">账号信息</view>
    <view class="meta-stack">
      <view class="label">身份：{{roleText}}</view>
      <view class="label">手机号：{{user.phone || '未填写'}}</view>
      <view class="label" wx:if="{{bindingStatusText}}">{{bindingStatusText}}</view>
    </view>
  </view>

  <button class="ghost-btn" bindtap="logout">退出登录</button>
</view>
