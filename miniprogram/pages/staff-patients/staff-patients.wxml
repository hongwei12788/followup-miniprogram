<view class="container">
  <view class="page-hero">
    <view class="eyebrow">患者管理</view>
    <view class="title">患者列表</view>
    <view class="subtitle">按姓名或手机号查找患者，进入详情查看手术、检查结果和随访记录。</view>
  </view>

  <input class="search-input" placeholder="搜索姓名或手机号" bindinput="onSearch" value="{{q}}" />
  <button class="primary-btn" bindtap="goAdd" type="primary">新增患者与手术</button>

  <view class="section-title">全部患者</view>
  <view wx:for="{{patients}}" wx:key="id" class="list-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="meta-row">
      <view class="item-title">{{item.name}}</view>
      <view class="status-pill">详情</view>
    </view>
    <view class="meta-stack">
      <view class="label">手机号：{{item.phone}}</view>
      <view class="label" wx:if="{{item.surgeries.length}}">最近手术：{{item.surgeries[0].surgeryName}}</view>
    </view>
  </view>

  <view wx:if="{{patients.length===0}}" class="empty-state">暂无患者数据</view>
</view>
